.pio_version 0 // only requires PIO version 0

.program fsk
    set pindirs, 1   ; Set pin to output
hipulse:
    set pins, 1  ; Drive pin high and then delay for one cycle
    ;jmp pin, lopulse
hipulselong:
    nop
    nop
    
lopulse:
    set pins, 0      ; Drive pin low
    ;jmp pin, hipulse

lopulselong:
    nop
    jmp hipulse

